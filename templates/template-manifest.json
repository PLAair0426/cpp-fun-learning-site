{
  "templateVersion": "1.2.0",
  "defaultProfile": "web-product",
  "textExtensions": [
    ".md",
    ".txt",
    ".json",
    ".ps1",
    ".yaml",
    ".yml",
    ".toml"
  ],
  "baseDirectories": [
    "assets/raw",
    "assets/research",
    "preparation/intake",
    "preparation/questions",
    "preparation/decisions",
    "templates/prompts",
    "templates/commands",
    "templates/documents",
    "templates/profiles",
    "generated/prd",
    "generated/spec",
    "generated/execution",
    "generated/review",
    "docs/product",
    "docs/technical",
    "docs/execution",
    "specification",
    "skills",
    ".template"
  ],
  "frameworkDirectories": [
    "bin",
    "lib"
  ],
  "scaffoldGlobs": [
    "README.md",
    "AGENTS.md",
    "assets/README.md",
    "preparation/README.md",
    "templates/README.md",
    "templates/template-manifest.json",
    "templates/template-config.example.json",
    "templates/commands/*.md",
    "templates/commands/*.ps1",
    "templates/documents/*.md",
    "templates/prompts/*.md",
    "templates/profiles/*.json",
    "templates/profiles/README.md",
    "generated/README.md",
    "docs/README.md",
    "skills/README.md",
    "specification/project-specification.md"
  ],
  "frameworkGlobs": [
    "package.json",
    "README.md",
    "AGENTS.md",
    "assets/README.md",
    "preparation/README.md",
    "templates/**",
    "generated/README.md",
    "docs/README.md",
    "specification/project-specification.md",
    "skills/**",
    "bin/**",
    "lib/**"
  ],
  "syncDefaults": {
    "managedGlobs": [
      "README.md",
      "AGENTS.md",
      "assets/README.md",
      "preparation/README.md",
      "templates/README.md",
      "templates/template-manifest.json",
      "templates/template-config.example.json",
      "templates/commands/*.md",
      "templates/commands/*.ps1",
      "templates/documents/*.md",
      "templates/prompts/*.md",
      "templates/profiles/*.json",
      "templates/profiles/README.md",
      "generated/README.md",
      "docs/README.md",
      "skills/README.md",
      "specification/project-specification.md"
    ],
    "protectedPrefixes": [
      "assets/raw/",
      "assets/research/",
      "preparation/intake/",
      "preparation/questions/",
      "preparation/decisions/",
      "generated/prd/",
      "generated/spec/",
      "generated/execution/",
      "generated/review/",
      "docs/product/",
      "docs/technical/",
      "docs/execution/"
    ]
  }
}
